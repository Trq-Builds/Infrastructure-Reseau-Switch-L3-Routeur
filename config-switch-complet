
!
version 12.2
no service pad
service timestamps debug datetime msec
service timestamps log datetime msec
no service password-encryption
!
hostname switch-1
!
boot-start-marker
boot-end-marker
!
!
no aaa new-model
switch 1 provision ws-c3750v2-24ts
system mtu routing 1500
ip subnet-zero
ip routing
no ip domain-lookup
!
!
!
!
crypto pki trustpoint TP-self-signed-815088384
 enrollment selfsigned
 subject-name cn=IOS-Self-Signed-Certificate-815088384
 revocation-check none
 rsakeypair TP-self-signed-815088384
!
!
crypto pki certificate chain TP-self-signed-815088384
 certificate self-signed 01 nvram:IOS-Self-Sig#3435.cer
!
!
!
!
!
spanning-tree mode pvst
spanning-tree extend system-id
!
vlan internal allocation policy ascending
!
!
!
!
interface FastEthernet1/0/1
 switchport access vlan 2
!
interface FastEthernet1/0/2
 switchport access vlan 2
!
interface FastEthernet1/0/3
 switchport access vlan 2
!
interface FastEthernet1/0/4
 switchport access vlan 2
!
interface FastEthernet1/0/5
 switchport access vlan 3
!
interface FastEthernet1/0/6
 switchport access vlan 3
!
interface FastEthernet1/0/7
 switchport access vlan 3
!
interface FastEthernet1/0/8
 switchport access vlan 3
!
interface FastEthernet1/0/9
 switchport access vlan 4
!
interface FastEthernet1/0/10
 switchport access vlan 4
!
interface FastEthernet1/0/11
 switchport access vlan 4
!
interface FastEthernet1/0/12
 switchport access vlan 4
!
interface FastEthernet1/0/13
!
interface FastEthernet1/0/14
!
interface FastEthernet1/0/15
!
interface FastEthernet1/0/16
!
interface FastEthernet1/0/17
!
interface FastEthernet1/0/18
!
interface FastEthernet1/0/19
!
interface FastEthernet1/0/20
!
interface FastEthernet1/0/21
!
interface FastEthernet1/0/22
 switchport access vlan 5
!
interface FastEthernet1/0/23
!
interface FastEthernet1/0/24
!
interface GigabitEthernet1/0/1
! 
interface GigabitEthernet1/0/2
!
interface Vlan1
 ip address 192.168.1.250 255.255.255.0
!
interface Vlan2
 ip address 10.0.0.255 255.0.0.0
 ip helper-address 192.168.0.1
!
interface Vlan3
 ip address 172.18.0.255 255.255.0.0
 ip helper-address 192.168.0.1
!
interface Vlan4
 ip address 192.168.0.254 255.255.255.0
!
interface Vlan5
 ip address 172.17.0.255 255.255.0.0
!
ip classless
ip route 0.0.0.0 0.0.0.0 172.17.0.1
ip http server
ip http secure-server
!
!
!
!
control-plane
!
!
line con 0
line vty 0 4
 login
line vty 5 15
 login
!
end
